DEBUG=True
SECRET_KEY=django-insecure-replace-this-in-production-with-a-long-random-string
ALLOWED_HOSTS=localhost,127.0.0.1

# Settings module — set this or pass --settings on every manage.py call
DJANGO_SETTINGS_MODULE=config.settings.development

# ---------------------------------------------------------------------------
# PostgreSQL — Docker Compose setup (recommended)
#
# When running via `docker compose up`, POSTGRES_HOST must be "db"
# (the service name inside the Docker network).
#
# When running the Django server locally (outside Docker) against a
# Dockerised DB, use POSTGRES_HOST=localhost and PORT=5433.
# ---------------------------------------------------------------------------
POSTGRES_DB=wynwood
POSTGRES_USER=wynwood
POSTGRES_PASSWORD=wynwood_dev
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Full DATABASE_URL — used by production.py and as a fallback
DATABASE_URL=postgresql://wynwood:wynwood_dev@db:5432/wynwood

# ---------------------------------------------------------------------------
# PostgreSQL — Local server (no Docker)
# Uncomment and adjust if you have PostgreSQL installed locally.
# ---------------------------------------------------------------------------
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5433
# DATABASE_URL=postgresql://wynwood:wynwood_dev@localhost:5433/wynwood

# ---------------------------------------------------------------------------
# SQLite (no database server needed — development only)
# ---------------------------------------------------------------------------
# DATABASE_URL=sqlite:///db.sqlite3

# ---------------------------------------------------------------------------
# Email
# ---------------------------------------------------------------------------
# Console backend — emails print to the terminal (development default)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=Wynwood House <noreply@wynwoodhouse.com>

# SMTP / API (uncomment and fill in for real email delivery)
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=apikey
# EMAIL_HOST_PASSWORD=your-sendgrid-or-mailgun-api-key
